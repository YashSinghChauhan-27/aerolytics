# ============================================================
# Environment variables required by Aerolytics backend
# Copy this to .env for local dev, or set these in Render dashboard
# ============================================================

# OpenAQ API key — get from https://explore.openaq.org/developers/keys
OPENAQ_API_KEY=your_openaq_api_key_here

# Comma-separated list of allowed CORS origins
# Example: https://aerolytics.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=https://your-frontend.vercel.app
